# Render sets this automatically when you link a PostgreSQL database to your service.
# Copy this to .env for local development and fill in your local PostgreSQL details.

PORT=3000

# Option 1: Use a full connection string (recommended)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Option 2: Use individual vars for local dev (used if DATABASE_URL is not set)
# DB_HOST=localhost
# DB_USER=postgres
# DB_PASSWORD=yourpassword
# DB_NAME=orders_db
# DB_PORT=5432
